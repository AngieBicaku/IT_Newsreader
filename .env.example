# Copy this to .env and adjust as needed

# Polling interval in seconds (default: 5 minutes)
POLL_INTERVAL_SECONDS=300

# Reddit subreddits to monitor (comma-separated)
REDDIT_SUBREDDITS=sysadmin,netsec,cybersecurity

# Minimum cosine similarity score to accept a news item (0.0 – 1.0)
RELEVANCE_THRESHOLD=0.12

# Recency decay rate (lambda). Higher = older items penalised more.
RECENCY_DECAY_LAMBDA=0.05

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
